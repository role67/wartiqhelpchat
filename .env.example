# Telegram
BOT_TOKEN=your_telegram_bot_token

# Neon/PostgreSQL
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Admin group IDs
COMMUNITY_CHAT_ID=-1003786067871
SUPPORT_CHAT_ID=-1003912146373

# Optional: admin IDs for moderation in private chat (comma-separated)
ADMIN_IDS=123456789,987654321

# Render/HTTP
PORT=10000

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log
